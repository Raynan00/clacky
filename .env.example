# Clacky configuration — copy to a real `.env` and fill in what you use.
#
# For the VOICE COMPANION (`clacky run`), put this at:  clacky/shell/.env
# For the FILE ORGANIZER  (`clacky organize`), the project root `.env` is fine.
# (A first-run setup wizard can also fill these in for you.)

# ─────────────────────────────────────────────────────────────────────
# VOICE COMPANION (clacky run)  — needs Claude; Deepgram strongly recommended
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # required for seeing / pointing / acting
DEEPGRAM_API_KEY=...                  # recommended: fast, accurate speech-to-text
                                      # (without it, falls back to slower local Whisper)
CLACKY_ACTIVE_LLM=claude              # claude | openai | gemini | ollama
CLACKY_HOTKEY=ctrl+alt+m              # push-to-talk hotkey (hold to talk)

# ─────────────────────────────────────────────────────────────────────
# FILE ORGANIZER (clacky organize)  — pick ONE provider, or use free modes
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # provider: claude  (best quality)
# OPENAI_API_KEY=sk-...               # provider: openai
# GOOGLE_API_KEY=AIza...              # provider: gemini

# --- Local / free (no key needed) ---
# OLLAMA_HOST=http://localhost:11434  # provider: ollama (default if no cloud key)
# CLACKY_OLLAMA_MODEL=llama3.1

# --- Force a provider regardless of keys ---
# CLACKY_PROVIDER=heuristic           # heuristic | ollama | claude | openai | gemini

# ─────────────────────────────────────────────────────────────────────
# OPTIONAL — Gmail / Calendar via the Google API (see clacky/shell/google_workspace.py)
# ─────────────────────────────────────────────────────────────────────
# Not set here — drop a Desktop OAuth client at ~/.clacky/google_credentials.json.
# Without it, Clacky just opens your logged-in Gmail/Calendar in the browser instead.
